{
    "name": "bneumann/opensearch-bundle",
    "description": "Symfony bundle providing native OpenSearch integration with Doctrine ORM support, index management, and blue/green reindexing.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "opensearch", "search", "doctrine", "indexing", "bundle"],
    "homepage": "https://github.com/bneumann/opensearch-bundle",
    "support": {
        "issues": "https://github.com/bneumann/opensearch-bundle/issues",
        "source": "https://github.com/bneumann/opensearch-bundle"
    },
    "autoload": {
        "psr-4": {
            "Bneumann\\OpensearchBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bneumann\\OpensearchBundle\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "B.Neumann",
            "email": "bastineu97@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "opensearch-project/opensearch-php": "^2.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "symfony/config": "^6.4 || ^7.0 || ^8.0",
        "symfony/console": "^6.4 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0",
        "symfony/serializer": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/yaml": "^6.4 || ^7.0 || ^8.0",
        "doctrine/orm": "^2.15 || ^3.0",
        "doctrine/doctrine-bundle": "^2.10"
    }
}
